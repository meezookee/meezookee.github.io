---
layout: base.liquid
---

<main class="list">
  <header>
    <h1>{{ title }}</h1>
  </header>

  {% for post in posts %}
  <article>
    <header>
      <h2>
        <a href="{{ post.url }}">
          {% if post.data.title %}
            {{ post.data.title }}
          {% else %}
            {{ post.date | toShortLocaleString }}
          {% endif %}
        </a>
      </h2>
    </header>
    <pre>{{ post.content | raw }}</pre>
    <footer>
      <time datetime="{{ post.date | toISOString }}">{{ post.date | toLocaleString }}</time>
    </footer>
  </article>
  {% endfor %}

  <footer>
    <nav>
      {% if pagination.href.previous %}
      <a class="previous" href="{{ pagination.href.previous }}">前</a>
      {% endif %}
      {% if pagination.href.next %}
      <a class="next" href="{{ pagination.href.next }}">次</a>
      {% endif %}
      <a class="up" href="{{ up.url }}">{{ up.title }}</a>
    </nav>
  </footer>
</main>
